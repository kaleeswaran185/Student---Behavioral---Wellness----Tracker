{
  "info": {
    "_postman_id": "d0c6f7b4-35ad-4d4d-a31f-phase2-student-wellness",
    "name": "Student Behavioral Wellness Tracker",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"teacher@school.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "Students - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{teacherToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"New Student\",\n  \"email\": \"new.student@school.test\",\n  \"grade\": \"10-A\",\n  \"risk\": \"Medium\"\n}"
        },
        "url": "{{baseUrl}}/api/students"
      }
    },
    {
      "name": "Students - List",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{teacherToken}}" }
        ],
        "url": "{{baseUrl}}/api/students"
      }
    },
    {
      "name": "History - Check-in",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{studentToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mood\": \"Happy\",\n  \"emoji\": \":)\",\n  \"note\": \"Feeling good\"\n}"
        },
        "url": "{{baseUrl}}/api/history/checkin"
      }
    },
    {
      "name": "Alerts - Trigger SOS",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{studentToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"alert\": {\n    \"severity\": \"High\",\n    \"type\": \"SOS Triggered\",\n    \"message\": \"Student requested immediate assistance.\"\n  }\n}"
        },
        "url": "{{baseUrl}}/api/alerts/sos"
      }
    },
    {
      "name": "Messages - Send",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{teacherToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"studentId\": \"{{studentId}}\",\n  \"text\": \"How are you feeling today?\"\n}"
        },
        "url": "{{baseUrl}}/api/messages"
      }
    },
    {
      "name": "Students - Delete",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{teacherToken}}" }
        ],
        "url": "{{baseUrl}}/api/students/{{studentId}}"
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "teacherToken", "value": "" },
    { "key": "studentToken", "value": "" },
    { "key": "studentId", "value": "" }
  ]
}
